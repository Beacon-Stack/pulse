# Built frontend — regenerated by `npm run build`, not committed.
# The placeholder.txt file is tracked so `//go:embed static` compiles on a
# fresh checkout before the frontend has been built (e.g. in CI for Go-only
# jobs). Real build output lands alongside it and stays gitignored.
web/static/*
!web/static/placeholder.txt

# Air (hot reload)
tmp/
.air.toml
